async function getThreats() {
  const cache = loadFromDisk();
  if (cache && Date.now() - cache.savedAt < CACHE_DURATION) return cache.data;

  console.log("Fetching fresh threat data from AbuseIPDB...");
  const raw = await fetchAbuseIPDB();

  if (!raw.length) {
    console.log("No IPs returned from AbuseIPDB — check API key");
    return [];
  }

  const usResolved = await geoResolve(raw);

  const seen    = new Set();
  const threats = usResolved
    .map(({ geo, raw }) => {
      const city       = snapToCity(geo.lat, geo.lon);
      const attackType = resolveAttackType(raw.categories);
      const score      = raw.confidence || 75;

 const realSector   = inferSector(geo.org, geo.company, geo.asnName);
const sector       = realSector || pick(FALLBACK_SECTORS);
const sectorIsReal = false; // no reliable victim sector source yet

      return {
        ip:          raw.ip,
        org:         geo.org,
        company:     geo.company,
        city:        city.city,
        state:       city.state,
        country:     "United States",
